{
    "compilerOptions": {
        "module": "esnext",
        "target": "es2024",
        "moduleResolution": "bundler",
        "paths": {},
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "noEmit": true,
        "rootDir": "./src",
        "types": [
            "bun-types"
        ]
    },
    "include": [
        "./src"
    ],
    "exclude": [
        "node_modules"
    ]
}
